    {
      "type": "text",
      "id": "formula_text",
      "x": 975,
      "y": 222,
      "width": 500,
      "height": 150,
      "text": "GraphSAGE Algorithm (Forward Pass):\n\nfor k = 1..K:\n  với mỗi node v:\n    h_N(v) = AGGREGATE_k({h_u, u in N(v)})\n    h_v(k) = sigma(W_k . CONCAT(h_v(k-1), h_N(v)))\n    h_v(k) = h_v(k) / ||h_v(k)||    (L2 normalize)\n\nz_v = h_v(K)  -- final embedding",
      "originalText": "GraphSAGE Algorithm (Forward Pass):\n\nfor k = 1..K:\n  với mỗi node v:\n    h_N(v) = AGGREGATE_k({h_u, u in N(v)})\n    h_v(k) = sigma(W_k . CONCAT(h_v(k-1), h_N(v)))\n    h_v(k) = h_v(k) / ||h_v(k)||    (L2 normalize)\n\nz_v = h_v(K)  -- final embedding",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 200112,
      "version": 1,
      "versionNonce": 200113,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": "formula_box",
      "lineHeight": 1.25
    },
