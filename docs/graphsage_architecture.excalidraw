    {
      "type": "text",
      "id": "unsup_formula_txt",
      "x": 128,
      "y": 926,
      "width": 578,
      "height": 44,
      "text": "J(z_v) = -log σ(z_v · z_u)   [node u đồng hành - positive]\n        - Q · E[log σ(-z_v · z_n)]   [Q negative nodes ngẫu nhiên]",
      "originalText": "J(z_v) = -log σ(z_v · z_u)   [node u đồng hành - positive]\n        - Q · E[log σ(-z_v · z_n)]   [Q negative nodes ngẫu nhiên]",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
