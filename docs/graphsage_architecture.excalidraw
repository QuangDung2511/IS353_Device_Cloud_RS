    {
      "type": "text",
      "id": "loss2_desc",
      "x": 100,
      "y": 697,
      "width": 1350,
      "height": 18,
      "text": "GraphSAGE không bị gắn chặt vào một hàm loss cố định — đây là điểm mạnh cốt lõi cho phép áp dụng vào nhiều bài toán khác nhau.",
      "originalText": "GraphSAGE không bị gắn chặt vào một hàm loss cố định — đây là điểm mạnh cốt lõi cho phép áp dụng vào nhiều bài toán khác nhau.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
